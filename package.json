{
  "name": "desktop-shell",
  "version": "0.1.0",
  "description": "A minimal Tauri React desktop shell.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "scripts": {
    "dev": "pnpm tauri dev",
    "build": "pnpm tauri build",
    "tauri": "tauri",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json}\" \"scripts/**/*.{js,mjs}\" \"docs/**/*.md\" \"README.md\" \"AGENTS.md\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json}\" \"scripts/**/*.{js,mjs}\" \"docs/**/*.md\" \"README.md\" \"AGENTS.md\"",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "test:tauri": "cd src-tauri && cargo test",
    "check:tauri": "cd src-tauri && cargo check",
    "postinstall": "pnpm exec update-browserslist-db || true",
    "update-browserslist-db": "pnpm exec update-browserslist-db",
    "sync:template": "node scripts/sync-template-config.mjs",
    "check:template-config": "node scripts/sync-template-config.mjs --check",
    "check:brand": "node scripts/check-brand.mjs",
    "check:shell-boundary": "node scripts/check-shell-boundary.mjs",
    "check:frontend-legacy": "node scripts/check-frontend-legacy-files.mjs",
    "check:template-deps": "node scripts/check-template-deps.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "check:app:frontend": "node scripts/check-template.mjs --app-frontend-only",
    "check:app:rust": "node scripts/check-template.mjs --app-rust-only",
    "check:app": "node scripts/check-template.mjs --app",
    "check:template:frontend": "node scripts/check-template.mjs --frontend-only",
    "check:template:rust": "node scripts/check-template.mjs --rust-only",
    "check:template": "node scripts/check-template.mjs",
    "check:all": "pnpm check:app",
    "icons:generate": "node scripts/generate-icons.mjs",
    "icons:check": "node scripts/generate-icons.mjs --check"
  },
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "update-browserslist-db": "^1.2.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@tanstack/react-query": "^5.101.2",
    "@tauri-apps/api": "^2.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/example/desktop-shell"
  }
}
